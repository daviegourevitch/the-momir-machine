    {
      "id": "comedy",
      "label": "Comedy",
      "filter": {
        "mode": "any_enabled",
        "field_rules": {
          "not_funny": {
            "op": "and",
            "rules": [
              { "op": "neq", "column": "set_type", "value": "funny" },
              { "op": "neq", "column": "border_color", "value": "silver" }
            ]
          },
          "silver_border": { "op": "eq", "column": "border_color", "value": "silver" },
          "non_silver_funny": {
            "op": "and",
            "rules": [
              { "op": "eq", "column": "set_type", "value": "funny" },
              { "op": "neq", "column": "border_color", "value": "silver" }
            ]
          }
        }
      },
      "advanced_fields": [
        {
          "id": "not_funny",
          "label": "Not funny",
          "type": "boolean",
          "default": true
        },
        {
          "id": "silver_border",
          "label": "Silver bordered cards",
          "type": "boolean",
          "default": false
        },
        {
          "id": "non_silver_funny",
          "label": "Non-silver funny cards",
          "type": "boolean",
          "default": false
        }
      ],
      "quick_options": [
        {
          "id": "not_funny",
          "label": "Only non-funny",
          "values": {
            "not_funny": true,
            "silver_border": false,
            "non_silver_funny": false
          }
        },
        {
          "id": "all_cards",
          "label": "All cards",
          "values": {
            "not_funny": true,
            "silver_border": true,
            "non_silver_funny": true
          }
        },
        {
          "id": "only_funny",
          "label": "Only funny",
          "values": {
            "not_funny": false,
            "silver_border": true,
            "non_silver_funny": true
          }
        }
      ]
    },
    {
      "id": "double_sided",
      "label": "Double Sided Cards",
      "show_advanced": false,
      "filter": {
        "mode": "selected_field_rule",
        "selected_field": "double_sided",
        "field_rules": {
          "true": { "op": "not_null", "column": "card_faces" },
          "false": { "op": "is_null", "column": "card_faces" }
        }
      },
      "advanced_fields": [
        {
          "id": "double_sided",
          "label": "Double Sided Cards",
          "type": "boolean",
          "default": false
        }
      ],
      "quick_options": [
        {
          "id": "single_sided",
          "label": "Disabled",
          "values": { "double_sided": false }
        },
        {
          "id": "double_sided",
          "label": "Enabled",
          "values": { "double_sided": true }
        }
      ]
    }
  ]
}
